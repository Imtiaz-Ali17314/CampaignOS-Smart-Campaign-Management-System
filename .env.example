# CampaignOS Environment Variables

# OpenAI API Key for the AI Content Generation Microservice
OPENAI_API_KEY=your_openai_api_key_here

# Model to use for generation (defaults to gpt-4o-mini if not set)
MODEL=gpt-4o-mini

# JWT Secret for secure authentication across API and Notification web socket
JWT_SECRET=super_secret_jwt_key_please_change_in_production
